{
  "schema_version": "v1",
  "template_name": "vsphere_vm",
  "template_description": "vSphere virtual machine Terraform configuration",
  "template_type": "terraform",
  "variables": [
    {
      "name": "datacenter_name",
      "description": "Name of the vSphere datacenter",
      "type": "string",
      "default": ""
    },
    {
      "name": "datastore_name",
      "description": "Name of the vSphere datastore",
      "type": "string",
      "default": ""
    },
    {
      "name": "cluster_name",
      "description": "Name of the vSphere compute cluster",
      "type": "string",
      "default": ""
    },
    {
      "name": "network_name",
      "description": "Name of the vSphere network",
      "type": "string",
      "default": "VM Network"
    },
    {
      "name": "vm_name",
      "description": "Name of the virtual machine",
      "type": "string",
      "default": ""
    },
    {
      "name": "num_cpus",
      "description": "Number of virtual CPUs",
      "type": "int",
      "default": "2"
    },
    {
      "name": "memory",
      "description": "Memory in MB",
      "type": "int",
      "default": "2048"
    },
    {
      "name": "disk_size",
      "description": "Disk size in GB",
      "type": "int",
      "default": "40"
    }
  ]
}
