apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .app_name }}-ingress
  namespace: {{ .namespace }}
spec:
  rules:
  - host: {{ .ingress_host }}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: {{ .app_name }}-service
            port:
              number: {{ .service_port }}
